@inject IJSRuntime JsRuntime

<footer class="footer">
    <div class="wrap">
        <div class="footer-top">
            <div>
                <div class="brand">
                    <img class="px"
                         src="@Images.Icons.Brand.Lion"
                         alt=""
                         style="width: 34px; height: 34px;" />

                    <span class="wm">
                        <b>Zoo Tycoon Nexus</b>

                        <small>Game Launcher</small>
                    </span>
                </div>

                <div class="footer-support"
                     style="margin-top: 22px">
                    <p>A community labour of love, built by one fan who got tired of fighting their own install. Free and OSS, forever. If it saved your afternoon, you can buy the
                       dev a coffee.</p>

                    <a href="#"
                       @onclick:preventDefault
                       aria-label="Support on Ko-fi">
                        <img class="kofi"
                             src="@Images.KofiBanner"
                             alt="Support me on Ko-fi" />
                    </a>
                </div>
            </div>

            <div class="footer-cols">
                <div class="footer-col">
                    <h5>Product</h5>

                    <!--suppress HtmlUnknownAnchorTarget -->
                    <a href="#fixes"
                       @onclick="@(() => ScrollToSection(sectionId: "fixes"))"
                       @onclick:preventDefault>Fixes</a>

                    <!--suppress HtmlUnknownAnchorTarget -->
                    <a href="#features"
                       @onclick="@(() => ScrollToSection(sectionId: "features"))"
                       @onclick:preventDefault>Features</a>

                    <!--suppress HtmlUnknownAnchorTarget -->
                    <a href="#how"
                       @onclick="@(() => ScrollToSection(sectionId: "how"))"
                       @onclick:preventDefault>How it works</a>

                    <!--suppress HtmlUnknownAnchorTarget -->
                    <a href="#roadmap"
                       @onclick="@(() => ScrollToSection(sectionId: "roadmap"))"
                       @onclick:preventDefault>Roadmap</a>

                    <!--suppress HtmlUnknownAnchorTarget -->
                    <a href="#contribute"
                       @onclick="@(() => ScrollToSection(sectionId: "contribute"))"
                       @onclick:preventDefault>Open Source</a>
                </div>

                <div class="footer-col">
                    <h5>Community</h5>

                    <!--suppress HtmlUnknownAnchorTarget -->
                    <a href="#"
                       @onclick:preventDefault>Discord</a>

                    <a href="@Links.NexusRepoUrl"
                       target="_blank"
                       rel="noopener noreferrer">GitHub</a>

                    <!--suppress HtmlUnknownAnchorTarget -->
                    <a href="#"
                       @onclick:preventDefault>Ko-fi</a>

                    <!--suppress HtmlUnknownAnchorTarget -->
                    <a href="#beta"
                       @onclick="@(() => ScrollToSection(sectionId: "beta"))"
                       @onclick:preventDefault>Join the beta</a>
                </div>
            </div>
        </div>

        <div class="footer-bottom">
            <p class="disc">
                Zoo Tycoon Nexus is a free, fan-made launcher and is <strong>not affiliated with, endorsed by, or associated with</strong> Microsoft or the rights holders of Zoo
                Tycoon. "Zoo Tycoon" is a trademark of its respective owners.
            </p>

            <span>© 2026 Zoo Tycoon Nexus · Made by the community</span>
        </div>
    </div>
</footer>

@code {

    private async Task ScrollToSection(string sectionId) => await JsRuntime.InvokeVoidAsync(identifier: "scrollToSection", sectionId);

}
