<form class="@FormCssClass"
      @onsubmit="HandleSubmit"
      @onsubmit:preventDefault
      novalidate>
    <div class="signup-row">
        @if (!Compact)
        {
            <input class="signup-name"
                   type="text"
                   placeholder="Your name (optional)"
                   value="@s_name"
                   @oninput="@(eventArgs => s_name = eventArgs.Value?.ToString() ?? string.Empty)"
                   aria-label="Your name" />
        }

        <input type="email"
               placeholder="you@email.com"
               value="@s_email"
               @oninput="HandleEmailInput"
               aria-label="Email address" />

        <button type="submit"
                class="btn btn-accent">@CallToAction</button>
    </div>

    <div class="signup-err">Hmm, that doesn't look like an email address.</div>

    <div class="micro micro-default">
        <img class="px"
             src="@Images.Icons.Win95.Information32Gif"
             alt="" />

        <span>No spam — one note when your beta key is ready. Unsubscribe anytime.</span>
    </div>

    <div class="signup-success">
        <img class="px"
             src="@Images.Icons.Win95.Mail24"
             alt="" />

        <div>
            <b>You're on the list@(string.IsNullOrWhiteSpace(s_name) ? string.Empty : $", {FirstName}")!</b>

            <span>We'll email <strong>@s_email</strong> the moment closed beta keys go out.</span>
        </div>
    </div>
</form>

@code {

    private enum SubmissionStates { Idle, ValidationError, Submitted }

    private static string s_email = string.Empty;

    private static string s_name = string.Empty;

    private static SubmissionStates s_submissionState = SubmissionStates.Idle;

    [ Parameter ]
    public string CallToAction { get; set; } = "Request beta access";

    [ Parameter ]
    public bool Compact { get; set; }

    private static string FormCssClass
        => s_submissionState switch
        {
            SubmissionStates.ValidationError => "signup err",
            SubmissionStates.Submitted       => "signup done",
            var _                            => "signup"
        };

    private static string FirstName
        => s_name.Trim() is { Length: > 0 } trimmedName
               ? trimmedName.Split(separator: ' ')[0]
               : string.Empty;

    private static void HandleEmailInput(ChangeEventArgs eventArgs)
    {
        s_email = eventArgs.Value?.ToString() ?? string.Empty;

        if (s_submissionState is SubmissionStates.ValidationError)
        {
            s_submissionState = SubmissionStates.Idle;
        }
    }

    private static void HandleSubmit()
    {
        bool isValidEmail = Regex.IsMatch(s_email.Trim(),
                                          pattern: @"^[^\s@]+@[^\s@]+\.[^\s@]+$");

        if (!isValidEmail)
        {
            s_submissionState = SubmissionStates.ValidationError;

            return;
        }

        s_submissionState = SubmissionStates.Submitted;
    }

}
