<section id="beta"
         class="section beta scan">
    <div class="wrap">
        <span class="eyebrow"
              style="color: #d8f0c8">Closed beta</span>

        <h2 class="beta-top"
            style="margin-top: 14px">Be first into the beta.</h2>

        <p class="beta-lead">
            Grab a spot in the closed beta. We'll send your key the moment the next wave opens —
            and you'll help refine the current features and decide what gets built next.
        </p>

        <div class="w95 beta-dialog">
            <div class="w95-title">
                <img class="t-ico px"
                     src="@Images.Icons.Win95.Mail24"
                     alt="" />

                <b>Join the Beta</b>

                <span class="spacer"></span>

                <span class="w95-tbtn">✕</span>
            </div>
            <div class="w95-body">
                <div class="dlg-head">
                    <img class="px"
                         src="@Images.Icons.Win95.Mail24"
                         alt="" />

                    <div>
                        <h2>Request your beta key</h2>

                        <p>Name optional. Email gets your invite. That's it.</p>
                    </div>
                </div>
                
                <EmailSignupForm CallToAction="Get my key" />
            </div>
        </div>
    </div>
</section>
