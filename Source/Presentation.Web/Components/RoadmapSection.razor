<section id="roadmap"
         class="section roadmap">
    <div class="wrap">
        <div class="section-head">
            <span class="eyebrow">On the roadmap</span>

            <h2>Beta gets you in early — and these land next.</h2>

            <p class="lead">
                Nexus already nails the basics. But we can do so much more, starting with
                the two things every long-time keeper asks for.
            </p>
        </div>

        <div class="road-grid">
            @foreach (RoadmapItem roadmapItem in RoadmapItems)
            {
                <article class="road-card">
                    <img class="critter px"
                         src="@roadmapItem.Icon"
                         alt="" />

                    <span class="road-status @GetStatusCssClass(roadmapItem.Status)">
                        @GetStatusLabel(roadmapItem.Status)
                    </span>

                    <h3>@((MarkupString)roadmapItem.Title)</h3>

                    <p class="rdesc">@((MarkupString)roadmapItem.Description)</p>

                    <ul class="road-list">
                        @foreach (string bulletPoint in roadmapItem.BulletPoints)
                        {
                            <li>@((MarkupString)bulletPoint)</li>
                        }
                    </ul>
                </article>
            }
        </div>

        <p class="road-note">
            Beta members help steer the direction — and get a direct line to the dev.
        </p>
    </div>
</section>

@code {

    private static readonly RoadmapItem[] RoadmapItems =
    [
        new(Images.Icons.Brand.Elephant,
            RoadmapStatuses.Planned,
            Title: "Save game management",
            Description: "Back up, restore, and organise your zoos — so a corrupt save never costs you a park you spent weeks building.",
            [
                "Automatic backups before every launch",
                "Restore any previous version of a save",
                "Organise and label saves by profile",
                "Cloud-folder friendly for easy syncing"
            ]),
        new(Images.Icons.Brand.Gate,
            RoadmapStatuses.NextUp,
            Title: "Custom content &amp; mod management",
            Description: "Install, toggle, and organise <code>.ztd</code> content packs without ever dumping loose files into your game directory again.",
            [
                "Drag-and-drop <code>.ztd</code> install &amp; uninstall",
                "Enable or disable packs per installation profile",
                "Conflict detection &amp; load-order control"
            ])
    ];

    private static string GetStatusCssClass(RoadmapStatuses status)
        => status switch
        {
            RoadmapStatuses.Planned => "planned",
            RoadmapStatuses.NextUp  => "beta",
            var _                   => string.Empty
        };

    private static string GetStatusLabel(RoadmapStatuses status)
        => status switch
        {
            RoadmapStatuses.Planned => "Planned",
            RoadmapStatuses.NextUp  => "Next up",
            var _                   => string.Empty
        };

}
