<section id="features" class="section features scan">
    <div class="wrap">
        <div class="section-head">
            <span class="eyebrow">What's in the box</span>
            <h2>A control panel for the classic you already love.</h2>
            <p class="lead">
                Everything the original game or other launcher never gave you — detection, repair, configuration,
                and a clean launch — in one tidy window.
            </p>
        </div>

        <div class="feat-grid">
            @foreach (FeatureItem feature in Features)
            {
                <article class="feat-card">
                    <div class="feat-ico">
                        <img class="px" src="@feature.Icon" alt="" />
                    </div>
                    <h3>@feature.Title</h3>
                    <p>@feature.Description</p>

                    @if (feature.Entries.Count > 0)
                    {
                        <div class="ini">
                            @foreach (IniEntry entry in feature.Entries)
                            {
                                <div>
                                    <span class="k">@entry.Key</span>
                                    <span> = </span>
                                    <span class="@entry.Kind.MapToCssToken()">@entry.Value</span>
                                </div>
                            }
                        </div>
                    }
                </article>
            }
        </div>
    </div>
</section>

